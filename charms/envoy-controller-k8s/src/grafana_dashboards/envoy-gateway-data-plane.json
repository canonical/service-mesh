{
  "__inputs": [],
  "__requires": [],
  "description": "Envoy Gateway data plane: request throughput, response classes and latency across managed Envoy proxies.",
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "Envoy Gateway - Data Plane Metrics",
  "uid": "envoy-gateway-data-plane",
  "templating": {
    "list": [
      { "name": "datasource", "query": "prometheus", "type": "datasource", "hide": 0 }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Downstream request rate",
      "datasource": { "type": "prometheus", "uid": "${prometheusds}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheusds}" },
          "expr": "sum(rate(envoy_http_downstream_rq_total[5m]))",
          "legendFormat": "requests",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Downstream responses by class",
      "datasource": { "type": "prometheus", "uid": "${prometheusds}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheusds}" },
          "expr": "sum by (envoy_response_code_class) (rate(envoy_http_downstream_rq_xx[5m]))",
          "legendFormat": "{{envoy_response_code_class}}xx",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Upstream request rate",
      "datasource": { "type": "prometheus", "uid": "${prometheusds}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheusds}" },
          "expr": "sum by (envoy_cluster_name) (rate(envoy_cluster_upstream_rq_total[5m]))",
          "legendFormat": "{{envoy_cluster_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Active upstream connections",
      "datasource": { "type": "prometheus", "uid": "${prometheusds}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheusds}" },
          "expr": "sum by (envoy_cluster_name) (envoy_cluster_upstream_cx_active)",
          "legendFormat": "{{envoy_cluster_name}}",
          "refId": "A"
        }
      ]
    }
  ]
}
